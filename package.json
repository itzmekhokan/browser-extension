{
  "name": "wordpress-browser-extension",
  "version": "0.9.0",
  "private": true,
  "description": "Browser extension that detects WordPress sites and surfaces admin/developer shortcuts.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WordPress/browser-extension.git"
  },
  "bugs": {
    "url": "https://github.com/WordPress/browser-extension/issues"
  },
  "homepage": "https://github.com/WordPress/browser-extension#readme",
  "scripts": {
    "build": "cross-env NODE_ENV=production wp-scripts build",
    "start": "cross-env NODE_ENV=development wp-scripts start",
    "build:safari": "npm run build && bash scripts/sync-safari.sh",
    "package:chrome": "bash scripts/package-chrome.sh"
  },
  "dependencies": {
    "@wordpress/icons": "^12.2.0",
    "@wordpress/ui": "^0.11.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@wordpress/scripts": "^30.0.0",
    "cross-env": "^7.0.3",
    "sharp": "^0.34.5"
  },
  "browserslist": [
    "last 2 Chrome versions",
    "last 2 Firefox versions",
    "last 2 Safari versions",
    "last 2 Edge versions"
  ]
}
